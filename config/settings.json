{
  "permissions": {
    "allow": [
      "mcp__context7",
      "mcp__serena",
      "mcp__sequential-thinking",
      "mcp__pencil"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/repos/coding-lab/plugins/dev-tools/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "life-manager@life-marketplace": true,
    "frontend-design@claude-code-plugins": true,
    "cloud-infrastructure@claude-code-workflows": true,
    "ui-design@claude-code-workflows": true,
    "agent-development@context-engineering-marketplace": true,
    "planning-with-files@planning-with-files": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "plugin-dev@claude-code-plugins": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "repomix": {
      "source": {
        "source": "github",
        "repo": "yamadashy/repomix"
      }
    },
    "awesome-claude-skills": {
      "source": {
        "source": "github",
        "repo": "ComposioHQ/awesome-claude-skills"
      }
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    },
    "context-engineering-marketplace": {
      "source": {
        "source": "github",
        "repo": "muratcankoylan/Agent-Skills-for-Context-Engineering"
      }
    },
    "claude-scientific-skills": {
      "source": {
        "source": "github",
        "repo": "K-Dense-AI/claude-scientific-skills"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": false,
  "voiceEnabled": true
}